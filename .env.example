# Backend
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Email Configuration (usando Gmail o tu servicio)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-aplicacion
SMTP_FROM=tu-email@gmail.com
CONTACT_EMAIL=tu-email@gmail.com

# Cloudflare Turnstile (obtén en https://dash.cloudflare.com/?to=/:account/turnstile)
CLOUDFLARE_TURNSTILE_SECRET=tu-secret-key
VITE_CLOUDFLARE_TURNSTILE_SITEKEY=tu-site-key
