      "id": "c3b4dbe3-d85f-41fe-b691-971f64b43bcd",
      "name": "1.-Recibir datos del Formulario",
      "webhookId": "REDACTED_WEBHOOK_ID"
    },
    {
      "parameters": {
        "jsCode": "  return items.map(item => {\n    try {\n      const startStr = item.json['Start date'];\n      const endStr = item.json['End date'];\n\n      if (!startStr || !endStr) {\n        return {\n          json: {\n            ...item.json,\n            'Dias': null,\n            'dias_error': 'Missing dates'\n          }\n        };\n      }\n\n      const start = new Date(startStr);\n      const end = new Date(endStr);\n\n      if (isNaN(start.getTime()) || isNaN(end.getTime())) {\n        return {\n          json: {\n            ...item.json,\n            'Dias': null,\n            'dias_error': 'Invalid date format'\n          }\n        };\n      }\n\n      const diffTime = Math.abs(end - start);\n      const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));\n      const dias = diffDays + 1; // +1 para inclusivo\n\n      return {\n        json: {\n          ...item.json,\n          'Dias': dias\n        }\n      };\n    } catch (error) {\n      return {\n        json: {\n          ...item.json,\n          'Dias': null,\n          'dias_error': error.message\n        }\n      };\n    }\n  });\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2416,
        384
      ],
      "id": "6194eaad-7603-4707-8329-affb85196b96",
      "name": "3.4.-Calcular Dias"
    },
    {
      "parameters": {
        "jsCode": "\n  return items.map(item => {\n    try {\n      const dobString = item.json['Date of birth'];\n      if (!dobString) {\n        return {\n          json: {\n            ...item.json,\n            'Edad ': null,\n            'edad_error': 'No date of birth provided'\n          }\n        };\n      }\n\n      const dob = new Date(dobString);\n      const hoy = new Date();\n\n      if (isNaN(dob.getTime())) {\n        return {\n          json: {\n            ...item.json,\n            'Edad ': null,\n            'edad_error': 'Invalid date format'\n          }\n        };\n      }\n\n      let edad = hoy.getFullYear() - dob.getFullYear();\n      const m = hoy.getMonth() - dob.getMonth();\n\n      if (m < 0 || (m === 0 && hoy.getDate() < dob.getDate())) {\n        edad--;\n      }\n\n      return {\n        json: {\n          ...item.json,\n          'Edad ': edad\n        }\n      };\n    } catch (error) {\n      return {\n        json: {\n          ...item.json,\n          'Edad ': null,\n          'edad_error': error.message\n        }\n      };\n    }\n  });\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1856,
        160
      ],
      "id": "d0e05dbd-99fe-4b01-8fcc-95823de8cf91",
      "name": "3.3.-Calcular Edad"
    },
    {
      "parameters": {
        "jsCode": "  const TARIFA_USD_POR_DIA = 2.9;\n\n  return items.map(item => {\n    try {\n      const dias = item.json.Dias;\n      let tipoCambio = item.json['Tipo de cambio'];\n\n      // Si no viene tipo de cambio, intentar extraer de la respuesta de Banxico\n      if (!tipoCambio && item.json.data && item.json.data.bmx) {\n        const datoRaw = item.json.data.bmx.series[0].datos[0].dato;\n        tipoCambio = parseFloat(String(datoRaw).replace(',', '.'));\n      }\n\n      // Fallback si no hay tipo de cambio\n      if (!tipoCambio) {\n        tipoCambio = 17.50; // Valor por defecto\n      }\n\n      let precioUSD = null;\n      let totalMXN = null;\n\n      if (dias && tipoCambio) {\n        precioUSD = Math.round(TARIFA_USD_POR_DIA * dias * 100) / 100;\n        totalMXN = Math.round(precioUSD * tipoCambio * 100) / 100;\n      }\n\n      return {\n        json: {\n          ...item.json,\n          'Precio USD': precioUSD,\n          'Total (MXN)': totalMXN,\n          'Tipo de cambio': tipoCambio\n        }\n      };\n    } catch (error) {\n      return {\n        json: {\n          ...item.json,\n          'Precio USD': null,\n          'Total (MXN)': null,\n          'precio_error': error.message\n        }\n      };\n    }\n  });"
      },
