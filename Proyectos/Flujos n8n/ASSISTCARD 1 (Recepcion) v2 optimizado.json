    {
      "parameters": {
        "jsCode": "return items.map(item => {\n  const data = item.json;\n  const dias = Number(data.dias);\n\n  let estado = \"\";\n  let tipo_precio = \"\";\n  let dias_validos = false;\n\n  if (dias < 60) {\n    estado = \"invalido_minimo\";\n  } else if (dias > 365) {\n    estado = \"invalido_maximo\";\n  } else {\n    dias_validos = true;\n\n    if (dias < 180) {\n      estado = \"precio_corto\";\n      tipo_precio = \"corto\";\n    } else {\n      estado = \"precio_normal\";\n      tipo_precio = \"normal\";\n    }\n  }\n\n  return {\n    json: {\n      ...data,\n      estado,\n      tipo_precio,\n      dias_validos\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -2240,
        160
      ],
      "id": "4c6813c2-da6d-40d7-a21f-d59399973f4b",
      "name": "2.-Validar dias"
    },
    {
      "parameters": {
